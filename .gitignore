# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual Environments ---
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# --- Jupyter Notebooks Caches ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/
.ipynb_checkpoints*

# --- Streamlit ---
.streamlit/config.toml
.streamlit/secrets.toml

# --- IDEs and Editors ---
# VS Code
.vscode/
# PyCharm / IntelliJ
.idea/
*.iml

# --- Operating Systems Debris ---
# macOS
.DS_Store
.AppleDouble
.LSOverride
# Windows
Thumbs.db
Desktop.ini

# --- Logs, Audits and Coverages ---
*.log
logs/
.pytest_cache/
.coverage
htmlcov/
.nosexy/

# --- Reports & Generated Artifacts ---
# Ignore generated report PDFs while retaining reports folder structure
reports/*.pdf
!reports/.gitkeep

# --- Models & Local Datasets Checkpoints ---
# Ignore temporary checks, keep original pickling models if committed
*.pkl.tmp
*.pickle.tmp
/datasets/sample_resumes.csv.tmp
/scratch/
tmp/
temp/
